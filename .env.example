# App
APP_NAME=Telegram Bot Maker
ENVIRONMENT=production
LOG_LEVEL=INFO
PORT=8000
DEFAULT_TIMEZONE=UTC

# Core Services
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/telegram_platform
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Telegram
MASTER_BOT_TOKEN=123456:MASTER_BOT_TOKEN_FROM_BOTFATHER
MASTER_BOT_WEBHOOK_SECRET=replace-with-random-secret
WEBHOOK_BASE_URL=https://your-railway-public-domain.up.railway.app
BOT_TOKEN_ENCRYPTION_KEY=GENERATE_FERNET_KEY_HERE
MASTER_ADMIN_IDS=123456789,987654321
PLATFORM_BRAND_HANDLE=@PlatformBot
OPS_API_KEY=change-this-strong-key

# Broadcast controls
BROADCAST_FLOOD_SLEEP=0.06
BROADCAST_MAX_RETRIES=5
BROADCAST_BATCH_SIZE=500
