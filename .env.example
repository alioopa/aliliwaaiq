# App
APP_NAME=Telegram Bot Maker
ENVIRONMENT=production
LOG_LEVEL=INFO
PORT=8000
DEFAULT_TIMEZONE=UTC

# Minimal mode defaults (works with MASTER_BOT_TOKEN only)
# Optional: replace with Railway Postgres/Redis references for full production mode.
DATABASE_URL=sqlite+aiosqlite:///./local.db
REDIS_URL=fakeredis://local
CELERY_BROKER_URL=memory://
CELERY_RESULT_BACKEND=cache+memory://

# Telegram
MASTER_BOT_TOKEN=123456:MASTER_BOT_TOKEN_FROM_BOTFATHER
MASTER_BOT_WEBHOOK_SECRET=replace-with-random-secret
WEBHOOK_BASE_URL=
# Optional in minimal mode; if empty a derived key is used.
BOT_TOKEN_ENCRYPTION_KEY=
MASTER_ADMIN_IDS=
PLATFORM_BRAND_HANDLE=@PlatformBot
OPS_API_KEY=

# Broadcast controls
BROADCAST_FLOOD_SLEEP=0.06
BROADCAST_MAX_RETRIES=5
BROADCAST_BATCH_SIZE=500
